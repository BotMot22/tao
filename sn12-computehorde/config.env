# SN12 ComputeHorde - Environment Configuration
# Copy to .env on your GPU server

# Wallet
WALLET_NAME=tao_miner
HOTKEY_NAME=default
WALLET_PATH=~/.bittensor/wallets

# Network
BITTENSOR_NETWORK=finney
NETUID=12

# GPU Server
GPU_SERVER_IP=<YOUR_GPU_SERVER_IP>
GPU_SERVER_USER=ubuntu
SSH_KEY_PATH=~/.ssh/id_rsa

# Executor Settings
# Stock single-executor is NOT competitive
# TODO: Build custom executor manager
MAX_EXECUTORS=4
EXECUTOR_TIMEOUT=300

# Collateral (for organic job eligibility)
# Deposit per validator - minimum 0.01 TAO (increasing to 10 TAO)
COLLATERAL_PER_VALIDATOR=0.01

# Docker
DOCKER_PRUNE_SCHEDULE="0 3 * * *"  # Daily at 3am
PRELOAD_IMAGES=true
