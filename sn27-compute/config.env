# SN27 Compute - Environment Configuration

# Wallet
WALLET_NAME=tao_miner
HOTKEY_NAME=default
WALLET_PATH=~/.bittensor/wallets

# Network
BITTENSOR_NETWORK=finney
NETUID=27

# Miner
AXON_PORT=8091
SSH_PORT=4444
TEST_SSH_PORT=4445
EXTERNAL_PORTS=27015-27018

# GPU (update to match your hardware)
GPU_TYPE=rtx_4090
GPU_COUNT=1

# Logging
LOG_LEVEL=info
